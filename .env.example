# Hostinger MySQL (Prisma)
# Replace values with your Hostinger database host/user/password/database
# Example host is often provided by hPanel (not always localhost)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"
PORT=3000

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="https://your-domain.tld/api/auth/google/callback"

# Frontend origin used by OAuth redirect
APP_ORIGIN="https://your-domain.tld"

# Runtime mode
NODE_ENV=production
