# Deezer OAuth2 credentials
# Create an app at https://developers.deezer.com/myapps
DEEZER_APP_ID=your_deezer_app_id
DEEZER_APP_SECRET=your_deezer_app_secret
DEEZER_REDIRECT_URI=http://localhost:3000/auth/deezer/callback

# Deezer Simple API (optional version prefix if needed later)
DEEZER_API_BASE_URL=https://api.deezer.com

# Google Gemini API key
# Obtain at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Spotify API credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Express session secret (set to a long random string)
SESSION_SECRET=change_this_to_a_random_secret

# Server port (optional, defaults to 3000)
PORT=3000
