# Hostinger MySQL (Sequelize)
# Replace values with your Hostinger database host/user/password/database
# Example host is often provided by hPanel (not always localhost)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"
DB_TIMEOUT_MS=8000
PORT=3000

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="https://your-domain.tld/api/auth/google/callback"

# Spotify OAuth
SPOTIFY_CLIENT_ID="replace-with-spotify-client-id"
SPOTIFY_CLIENT_SECRET="replace-with-spotify-client-secret"
SPOTIFY_CALLBACK_URL="https://your-domain.tld/api/auth/spotify/callback"

# YouTube / Google OAuth for YouTube Music import
# Can reuse the same Google Cloud project as Google sign-in, with YouTube Data API enabled.
YOUTUBE_CLIENT_ID="replace-with-youtube-client-id-or-google-client-id"
YOUTUBE_CLIENT_SECRET="replace-with-youtube-client-secret-or-google-client-secret"
YOUTUBE_CALLBACK_URL="https://your-domain.tld/api/auth/youtube/callback"

# Deezer OAuth
DEEZER_APP_ID="replace-with-deezer-app-id"
DEEZER_APP_SECRET="replace-with-deezer-app-secret"
DEEZER_CALLBACK_URL="https://your-domain.tld/api/auth/deezer/callback"

# Frontend origin used by OAuth redirect
APP_ORIGIN="https://your-domain.tld"

# Runtime mode
NODE_ENV=production
