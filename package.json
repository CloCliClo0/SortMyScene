{
  "name": "sortmyscene",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack app for AI-powered music scene curation",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "nodemon server.js",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web install --ignore-scripts --include=dev --include=optional && npm --prefix web run build",
    "build": "npm --prefix web install --ignore-scripts --include=dev --include=optional && npm run build:web",
    "postinstall": "npm run build:web",
    "start": "node server.js",
    "test:db": "node test-db.js",
    "create:admin": "node scripts/create-admin.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.2",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.7"
  }
}
